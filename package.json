{
  "name": "noted",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "turbo run dev --filter=./apps/*",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@noted/database",
    "db:migrate": "turbo run db:migrate --filter=@noted/database",
    "db:push": "turbo run db:push --filter=@noted/database",
    "deploy": "turbo run deploy --filter=./apps/*"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.7.2"
  }
}
